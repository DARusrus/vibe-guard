{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "vibe-guard",
          "version": "0.1.0",
          "informationUri": "https://github.com/ahmbt/vibe-guard",
          "rules": [
            {
              "id": "src.vibeguard.rules.python.vibeguard-python-hardcoded-secret-assignment",
              "name": "Src.vibeguard.rules.python.vibeguardPythonHardcodedSecretAssignment",
              "shortDescription": {
                "text": "Hardcoded credential detected. This value is embedded directly in source code and will be exposed in version control.\n"
              },
              "fullDescription": {
                "text": "Hardcoded credential detected. This value is embedded directly in source code and will be exposed in version control.\n. Move this value to an environment variable. Use os.environ.get('VAR_NAME') in your code and document required variables in .env.example. Never commit credentials."
              },
              "helpUri": "https://github.com/ahmbt/vibe-guard/blob/main/rules/",
              "properties": {
                "tags": [
                  "secrets",
                  "security",
                  "ai-generated"
                ],
                "severity": "CRITICAL",
                "cwe": "CWE-798: Use of Hard-coded Credentials"
              }
            },
            {
              "id": "src.vibeguard.rules.python.vibeguard-python-sqli-fstring",
              "name": "Src.vibeguard.rules.python.vibeguardPythonSqliFstring",
              "shortDescription": {
                "text": "SQL injection via string interpolation in execute() call. User-controlled input is directly embedded into the SQL query string.\n"
              },
              "fullDescription": {
                "text": "SQL injection via string interpolation in execute() call. User-controlled input is directly embedded into the SQL query string.\n. Use parameterized queries instead of string interpolation. Replace cursor.execute(f\"SELECT * FROM users WHERE id = {user_id}\") with cursor.execute(\"SELECT * FROM users WHERE id = %s\", (user_id,))"
              },
              "helpUri": "https://github.com/ahmbt/vibe-guard/blob/main/rules/",
              "properties": {
                "tags": [
                  "sqli",
                  "security",
                  "ai-generated"
                ],
                "severity": "CRITICAL",
                "cwe": "CWE-89: Improper Neutralization of Special Elements in SQL Command"
              }
            },
            {
              "id": "src.vibeguard.rules.python.vibeguard-python-weak-password-hash",
              "name": "Src.vibeguard.rules.python.vibeguardPythonWeakPasswordHash",
              "shortDescription": {
                "text": "Fast hash functions are unsafe for password storage and enable offline brute-force attacks at high guess rates.\n"
              },
              "fullDescription": {
                "text": "Fast hash functions are unsafe for password storage and enable offline brute-force attacks at high guess rates.\n. Use bcrypt or Argon2 for password hashing. Example: bcrypt.hashpw(password.encode(), bcrypt.gensalt())."
              },
              "helpUri": "https://github.com/ahmbt/vibe-guard/blob/main/rules/",
              "properties": {
                "tags": [
                  "password_hash",
                  "security",
                  "ai-generated"
                ],
                "severity": "CRITICAL",
                "cwe": "CWE-916: Use of Password Hash With Insufficient Computational Effort"
              }
            },
            {
              "id": "src.vibeguard.rules.python.vibeguard-python-path-traversal-unsanitized",
              "name": "Src.vibeguard.rules.python.vibeguardPythonPathTraversalUnsanitized",
              "shortDescription": {
                "text": "Path traversal vulnerability. User-controlled input is used directly in a file path without sanitization, allowing directory traversal attacks.\n"
              },
              "fullDescription": {
                "text": "Path traversal vulnerability. User-controlled input is used directly in a file path without sanitization, allowing directory traversal attacks.\n. Normalize the path with os.path.abspath() and validate it stays within the intended directory using os.path.commonpath(). Example: safe_path = os.path.abspath(os.path.join(base_dir, filename)); assert os.path.commonpath([base_dir, safe_path]) == base_dir"
              },
              "helpUri": "https://github.com/ahmbt/vibe-guard/blob/main/rules/",
              "properties": {
                "tags": [
                  "path_traversal",
                  "security",
                  "ai-generated"
                ],
                "severity": "HIGH",
                "cwe": "CWE-22: Improper Limitation of a Pathname to a Restricted Directory"
              }
            },
            {
              "id": "src.vibeguard.rules.python.vibeguard-python-ssrf-user-controlled-url",
              "name": "Src.vibeguard.rules.python.vibeguardPythonSsrfUserControlledUrl",
              "shortDescription": {
                "text": "Server-Side Request Forgery (SSRF) risk. A URL from user-controlled input is passed directly to an HTTP client without validation.\n"
              },
              "fullDescription": {
                "text": "Server-Side Request Forgery (SSRF) risk. A URL from user-controlled input is passed directly to an HTTP client without validation.\n. Validate the URL against an allowlist of permitted domains. Block requests to private IP ranges (10.x, 172.16-31.x, 192.168.x, 127.x, 169.254.x). Use urllib.parse.urlparse() to extract the host and compare against the allowlist before making the request."
              },
              "helpUri": "https://github.com/ahmbt/vibe-guard/blob/main/rules/",
              "properties": {
                "tags": [
                  "ssrf",
                  "security",
                  "ai-generated"
                ],
                "severity": "HIGH",
                "cwe": "CWE-918: Server-Side Request Forgery"
              }
            },
            {
              "id": "src.vibeguard.rules.python.vibeguard-python-cmdi-shell-true",
              "name": "Src.vibeguard.rules.python.vibeguardPythonCmdiShellTrue",
              "shortDescription": {
                "text": "Command injection risk via subprocess call with shell=True and dynamic command string. User input may be injected into the shell command.\n"
              },
              "fullDescription": {
                "text": "Command injection risk via subprocess call with shell=True and dynamic command string. User input may be injected into the shell command.\n. Use a list of arguments instead of a shell string. Replace subprocess.run(f\"cmd {user_input}\", shell=True) with subprocess.run([\"cmd\", user_input], shell=False)."
              },
              "helpUri": "https://github.com/ahmbt/vibe-guard/blob/main/rules/",
              "properties": {
                "tags": [
                  "cmdi",
                  "security",
                  "ai-generated"
                ],
                "severity": "HIGH",
                "cwe": "CWE-78: Improper Neutralization of Special Elements in OS Command"
              }
            }
          ]
        }
      },
